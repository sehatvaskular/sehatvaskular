import { supabase } from '@/lib/supabase'
import Link from 'next/link'

// Revalidate setiap 60 detik (ISR) agar konten fresh tanpa rebuild
export const revalidate = 60 

export default async function Home() {
  const { data: posts } = await supabase
    .from('posts')
    .select('title, slug, excerpt, published_at')
    .order('published_at', { ascending: false })

  return (
    <main className="max-w-4xl mx-auto p-8">
      <h1 className="text-4xl font-bold mb-8 text-blue-900">Sehat Vaskular</h1>
      <div className="grid gap-6">
        {posts?.map((post) => (
          <article key={post.slug} className="p-6 border rounded-xl shadow-sm hover:shadow-md transition">
            <Link href={`/artikel/${post.slug}`}>
              <h2 className="text-2xl font-semibold text-gray-800 hover:text-blue-600">{post.title}</h2>
            </Link>
            <p className="text-gray-600 mt-2">{post.excerpt}</p>
          </article>
        ))}
      </div>
    </main>
  )
}